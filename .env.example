# ── LLM API 키 (둘 중 하나만 있으면 됩니다) ──────────────────────────────────
# Gemini 사용 시 (VITE_ 접두 → 프론트엔드 갭분석 + 백엔드 면접 생성에 사용)
VITE_GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_API_KEY=your_google_api_key_here   # 백엔드 전용 (VITE_ 없는 버전)

# OpenAI 사용 시 (팀원 호환 — 위 Gemini 키가 없을 때 자동 fallback)
OPENAI_API_KEY=your_openai_api_key_here

# ── 백엔드 URL ────────────────────────────────────────────────────────────────
# FastAPI 백엔드 주소 (로컬 개발: http://localhost:8000)
VITE_BACKEND_URL=http://localhost:8000

# ── 벡터 DB / 임베딩 ─────────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# ── 선택 사항 ─────────────────────────────────────────────────────────────────
# Tavily 실시간 검색 (agent/brief 엔드포인트에서 사용)
TAVILY_API_KEY=
