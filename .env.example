# OpenAI — required for frontend LLM calls
OPENAI_API_KEY=your_openai_api_key_here

# FastAPI backend URL — consumed by Vite as VITE_BACKEND_URL
# Set to your deployed URL in production; defaults to http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000

# Vector DB Settings — used by the Python pipeline and FastAPI backend
CHROMA_DB_PATH=./chroma_db
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# RAG similarity threshold (default 0.4, see docs/rag-threshold-analysis.md)
RAG_SIMILARITY_THRESHOLD=0.4

# Optional — used by /api/agent/brief for realtime search augmentation
TAVILY_API_KEY=your_tavily_api_key_here
