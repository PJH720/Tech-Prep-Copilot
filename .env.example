# ── LLM API 키 (failover: Gemini → OpenAI → Upstage, 순서는 LLM_PROVIDER_ORDER) ─
# Gemini
VITE_GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI (한 키만 있어도 면접·갭 분석 동작)
OPENAI_API_KEY=your_openai_api_key_here

# Upstage (Solar 등, OpenAI 호환 엔드포인트)
UPSTAGE_API_KEY=
UPSTAGE_MODEL=solar-pro
# UPSTAGE_API_BASE=https://api.upstage.ai/v1

# 시도 순서 및 타임아웃
# LLM_PROVIDER_ORDER=gemini,openai,upstage
# LLM_TIMEOUT_SEC=60
# GEMINI_MODEL=gemini-2.5-flash-lite
# OPENAI_MODEL=gpt-4o-mini

# ── 백엔드 URL ────────────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:8000

# ── 벡터 DB / 임베딩 ─────────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db
# Auto-extracted from data/chroma_db1.zip on first backend startup if missing.
# To rebuild from scratch: python utils/build_vectorstore.py
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# RAG similarity threshold (default 0.4, see docs/rag-threshold-analysis.md)
RAG_SIMILARITY_THRESHOLD=0.2

# Multi-query expansion (Advanced RAG)
# RAG_QUERY_EXPANSION=1
# RAG_QUERY_EXPANSION_COUNT=3
# RAG_REWRITE_MODEL=gpt-4o-mini

# ── 선택: 실시간 검색 (agent/brief) ─────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here
